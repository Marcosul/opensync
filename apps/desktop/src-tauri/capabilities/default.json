{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities por defeito para a janela principal do OpenSync Desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default",
    "shell:allow-open",
    "dialog:default",
    "opener:allow-open-url"
  ]
}
