PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# URL pública HTTPS do .deb (GET /install/ubuntu). Opcional se usares Supabase abaixo com bucket público `installer/`.
# OPENSYNC_UBUNTU_DEB_URL=https://<project>.supabase.co/storage/v1/object/public/installer/opensync-ubuntu_0.1.0_amd64.deb
# Se vazio e NEXT_PUBLIC_SUPABASE_URL definido: mesmo caminho em .../storage/v1/object/public/installer/opensync-ubuntu_0.1.0_amd64.deb
# Senão: {NEXT_PUBLIC_APP_URL ou https://opensync.space}/releases/opensync-ubuntu_0.1.0_amd64.deb
# OPENSYNC_UBUNTU_DEB_URL=http://localhost:3000/releases/opensync-ubuntu_0.1.0_amd64.deb
# Base URL da API Nest (com /api). Usada no assistente OpenClaw para OPENSYNC_API_URL.
# Produção: https://api.opensync.space/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api
# URL e chaves devem ser do MESMO projeto em dashboard.supabase.com (Settings > API).
# Auth > Providers > Google precisa estar ON nesse mesmo projeto.
NEXT_PUBLIC_SUPABASE_URL=
# Public client key: classic `anon` JWT or publishable key (`sb_publishable_...`)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Do not add service_role or secret keys with NEXT_PUBLIC_ — they are exposed in the browser
