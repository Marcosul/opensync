# Obrigatorio em conjunto: DATABASE_URL (pode ser pooler :6543) + DIRECT_URL (sempre sessao/direct :5432).
# Fly: definir os dois em secrets; migrate deploy usa DIRECT_URL (evita erro PgBouncer "prepared statement already exists").
DATABASE_URL=postgresql://user:password@localhost:5432/opensync
DIRECT_URL=postgresql://user:password@localhost:5432/opensync
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# pnpm deb:opensync-ubuntu: usa SUPABASE_* acima para upload do .deb ao Storage (bucket installer, upsert).
# Same Gitea for local API and Fly (see docs/dev/gitea-ionos-first-install.md)
GITEA_URL=http://YOUR_VPS_IP:3000
# PAT com write:organization + write:repository (ver docs/dev/gitea-ionos-first-install.md).
# A API cria uma org Gitea por workspace (username ws + uuid).
GITEA_ADMIN_TOKEN=your-gitea-admin-token
JWT_SECRET=your-jwt-secret
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
APP_URL=http://localhost:3100
PORT=3101
OPENSYNC_COLLAB_SHARED_SECRET=_VbPKgmuAB89efwfnXgKGsaEwWo_NrKVoINaWT1AT9N_eyVfaI7Rsb2np8cULdCY

