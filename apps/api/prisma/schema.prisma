generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id               String   @id @db.Uuid
  email            String
  plan             String   @default("free")
  stripeCustomerId String?  @map("stripe_customer_id")
  createdAt        DateTime @default(now()) @map("created_at")

  vaults    Vault[]
  auditLogs AuditLog[]

  @@map("profiles")
}

model Vault {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  description String?
  giteaRepo String   @map("gitea_repo")
  path      String   @default("./openclaw")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  user      Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)
  agents    Agent[]
  commits   Commit[]
  fileLinks FileLink[]
  auditLogs AuditLog[]

  @@map("vaults")
}

model Agent {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vaultId   String    @map("vault_id") @db.Uuid
  name      String
  tokenHash String    @map("token_hash")
  lastSync  DateTime? @map("last_sync")
  createdAt DateTime  @default(now()) @map("created_at")

  vault   Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  commits Commit[]

  @@map("agents")
}

model Commit {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vaultId      String   @map("vault_id") @db.Uuid
  agentId      String?  @map("agent_id") @db.Uuid
  hash         String
  message      String
  filesChanged Int      @default(0) @map("files_changed")
  additions    Int      @default(0)
  deletions    Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  vault Vault  @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  agent Agent? @relation(fields: [agentId], references: [id])

  @@map("commits")
}

model FileLink {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vaultId    String   @map("vault_id") @db.Uuid
  sourceFile String   @map("source_file")
  targetFile String   @map("target_file")
  updatedAt  DateTime @updatedAt @map("updated_at")

  vault Vault @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@unique([vaultId, sourceFile, targetFile])
  @@map("file_links")
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  vaultId   String?  @map("vault_id") @db.Uuid
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user  Profile? @relation(fields: [userId], references: [id])
  vault Vault?   @relation(fields: [vaultId], references: [id])

  @@map("audit_log")
}
