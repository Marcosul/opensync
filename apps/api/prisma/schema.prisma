generator client {
  provider      = "prisma-client-js"
  // bookworm-slim (Fly/Docker) usa OpenSSL 3; dev local continua com "native"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Runtime: pooler Supabase (6543). Migrações: DIRECT_URL na porta 5432 (evita "prepared statement already exists" no PgBouncer).
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
