model Vault {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  name        String
  description String?
  giteaRepo   String   @map("gitea_repo")
  path        String   @default("./openclaw")
  isActive    Boolean  @default(true) @map("is_active")
  /// ID da deploy key no Gitea (chave publica registada para o agente na VPS). A privada nunca e guardada na base.
  agentDeployKeyGiteaId Int? @map("agent_deploy_key_gitea_id")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agents    Agent[]
  commits   Commit[]
  fileLinks        FileLink[]
  auditLogs        AuditLog[]
  vaultFiles       VaultFile[]
  vaultFileChanges VaultFileChange[]
  giteaMirrorState VaultGiteaMirrorState?

  @@unique([workspaceId, name])
  @@map("vaults")
}
