[Unit]
Description=OpenSync Ubuntu (vault sync)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/node /usr/lib/opensync-ubuntu/dist/cli.js run
Restart=always
RestartSec=5
# Mantém o agente mesmo quando o utilizador não tem sessão gráfica (ex.: só SSH).
Environment=NODE_ENV=production

[Install]
WantedBy=default.target
