# Copy to gitea.env on the server and set PUBLIC_HOST to the VPS IPv4 or DNS name.
USER_UID=1000
USER_GID=1000
GITEA__database__DB_TYPE=sqlite3
GITEA__server__HTTP_PORT=3000
GITEA__server__SSH_LISTEN_PORT=22
# Replace with your host (no trailing path except ROOT_URL)
PUBLIC_HOST=216.250.124.232
GITEA__server__ROOT_URL=http://216.250.124.232:3000/
GITEA__server__DOMAIN=216.250.124.232
GITEA__server__SSH_DOMAIN=216.250.124.232
GITEA__server__SSH_PORT=2222
